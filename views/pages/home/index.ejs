<!-- Pricing Toggles Section -->
<section style="padding: 4rem 1.5rem;">
    <div class="container text-center">
        <h2 style="font-size: 2.25rem; font-weight: 800; margin-bottom: 1.5rem;">Pricing Structures</h2>
        
        <!-- Toggle button -->
        <div style="display: inline-flex; align-items: center; gap: 1rem; background: var(--bg-secondary); border: 1px solid var(--border-color); padding: 0.35rem; border-radius: 99px; margin-bottom: 3rem;">
            <button id="btn-pricing-monthly" class="btn btn-small btn-primary" style="border-radius:99px; padding:0.4rem 1.25rem;">Monthly</button>
