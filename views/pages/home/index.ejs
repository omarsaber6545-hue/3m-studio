<!-- FAQ Accordion List -->
<section style="padding: 4rem 1.5rem; background: rgba(0,0,0,0.15);">
    <div class="container" style="max-width: 700px;">
        <div class="text-center" style="margin-bottom: 2.5rem;">
            <h2 style="font-size: 2.25rem; font-weight: 800; margin-bottom: 0.5rem;">Frequently Asked Questions</h2>
            <p style="color: var(--text-muted);">Have questions about credits billing or API configurations?</p>
        </div>

        <input type="search" id="faq-search" placeholder="Search FAQ questions..." style="width: 100%; padding: 0.85rem 1.25rem; border-radius: 8px; border: 1px solid var(--border-color); background: var(--bg-primary); color: var(--text-primary); outline: none; margin-bottom: 2rem; font-family: inherit; font-size: 0.9rem;">

        <div style="display: flex; flex-direction: column; gap: 1rem; text-align: left;">
            <div class="faq-item glass-card" style="padding: 1rem 1.25rem; cursor: pointer;">
                <div style="display:flex; justify-content:space-between; font-weight:600; font-size:0.95rem;">
                    <span>Can I bring my own API keys?</span>
                    <span class="faq-icon">▼</span>
                </div>
                <div class="faq-answer" style="display:none; font-size:0.85rem; color:var(--text-muted); margin-top:0.75rem; line-height:1.6;">
                    Yes. Under the security profile tab, Pro and Enterprise tier accounts can link their own Google Gemini, OpenAI, Claude, or DeepSeek API credentials directly to skip credits limits.
                </div>
            </div>
            
            <div class="faq-item glass-card" style="padding: 1rem 1.25rem; cursor: pointer;">
                <div style="display:flex; justify-content:space-between; font-weight:600; font-size:0.95rem;">
                    <span>How does Discord login work?</span>
                    <span class="faq-icon">▼</span>
                </div>
                <div class="faq-answer" style="display:none; font-size:0.85rem; color:var(--text-muted); margin-top:0.75rem; line-height:1.6;">
                    You can authorize 3M Studio using your Discord credentials. This creates or links to a unified workspace profile containing your display names and avatar badges securely.
                </div>
            </div>
        </div>
    </div>
</section>

<script>
    // Live countdown timer execution
    const countdownEl = document.getElementById('announcement-countdown');
    const targetDate = new Date().getTime() + 7 * 24 * 60 * 60 * 1000; // 7 days countdown
    
    setInterval(() => {
        const now = new Date().getTime();
        const diff = targetDate - now;
        
        const days = Math.floor(diff / (1000 * 60 * 60 * 24));
        const hours = Math.floor((diff % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
        const minutes = Math.floor((diff % (1000 * 60 * 60)) / (1000 * 60));
        const seconds = Math.floor((diff % (1000 * 60)) / 1000);
        
        if (countdownEl) {
            countdownEl.textContent = `${days}d ${hours}h ${minutes}m ${seconds}s`;
        }
    }, 1000);

    // Pricing Plan toggle switches
    const btnMonthly = document.getElementById('btn-pricing-monthly');
    const btnYearly = document.getElementById('btn-pricing-yearly');
    
    const priceStarter = document.getElementById('price-starter');
    const pricePro = document.getElementById('price-pro');
    const priceEnterprise = document.getElementById('price-enterprise');

    if (btnMonthly && btnYearly) {
        btnMonthly.addEventListener('click', () => {
            btnMonthly.className = "btn btn-small btn-primary";
            btnYearly.className = "btn btn-small btn-outline";
            priceStarter.innerHTML = '$19<span style="font-size:1rem; font-weight:500; color:var(--text-muted);">/mo</span>';
            pricePro.innerHTML = '$49<span style="font-size:1rem; font-weight:500; color:var(--text-muted);">/mo</span>';
            priceEnterprise.innerHTML = '$149<span style="font-size:1rem; font-weight:500; color:var(--text-muted);">/mo</span>';
        });

        btnYearly.addEventListener('click', () => {
            btnYearly.className = "btn btn-small btn-primary";
            btnMonthly.className = "btn btn-small btn-outline";
            priceStarter.innerHTML = '$15<span style="font-size:1rem; font-weight:500; color:var(--text-muted);">/mo</span>';
            pricePro.innerHTML = '$39<span style="font-size:1rem; font-weight:500; color:var(--text-muted);">/mo</span>';
            priceEnterprise.innerHTML = '$119<span style="font-size:1rem; font-weight:500; color:var(--text-muted);">/mo</span>';
        });
    }

    // FAQ Accordion clicks
    const faqItems = document.querySelectorAll('.faq-item');
    faqItems.forEach(item => {
        item.addEventListener('click', () => {
            const answer = item.querySelector('.faq-answer');
            const icon = item.querySelector('.faq-icon');
            const isVisible = answer.style.display === 'block';
            answer.style.display = isVisible ? 'none' : 'block';
            icon.style.transform = isVisible ? 'rotate(0deg)' : 'rotate(180deg)';
        });
    });

    // FAQ Search queries
    const faqSearch = document.getElementById('faq-search');
    if (faqSearch) {
        faqSearch.addEventListener('input', (e) => {
            const query = e.target.value.toLowerCase().trim();
            faqItems.forEach(item => {
                const text = item.textContent.toLowerCase();
                item.style.display = text.includes(query) ? 'block' : 'none';
            });
        });
    }
</script>
