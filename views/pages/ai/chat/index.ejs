<div style="display: flex; height: calc(100vh - var(--header-height)); background: var(--bg-primary); overflow: hidden;">
    <!-- Left Sidebar -->
    <aside style="width: 280px; border-right: 1px solid var(--border-color); background: var(--bg-secondary); display: flex; flex-direction: column; justify-content: space-between; flex-shrink: 0;">
        <div style="padding: 1.25rem; display: flex; flex-direction: column; gap: 1rem; overflow-y: auto; flex: 1;">
            <button class="btn btn-primary w-full" id="btn-chat-new" style="display: flex; align-items: center; justify-content: center; gap: 0.5rem;">
                <span>+</span> New Conversation
            </button>
            
            <input type="search" id="chat-search-input" placeholder="Search conversations..." style="width: 100%; padding: 0.5rem 1rem; border-radius: 20px; border: 1px solid var(--border-color); background: rgba(0,0,0,0.2); color: var(--text-primary); outline: none; font-size: 0.85rem; font-family: inherit;">
            
            <div style="display: flex; flex-direction: column; gap: 1.5rem; text-align: left; margin-top: 1rem;">
                <div>
                    <span style="font-size: 0.7rem; font-weight: 700; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.05em;">🕒 Generation History</span>
                    <div id="chat-history-list" style="display: flex; flex-direction: column; gap: 0.25rem; margin-top: 0.5rem;">
                        <!-- AI prompt history loaded here dynamically -->
                        <div style="font-size: 0.75rem; color: var(--text-muted); text-align: center; padding: 1rem;">No recent generations</div>
                    </div>
                </div>
            </div>
        </div>
        
        <div style="padding: 1rem; border-top: 1px solid var(--border-color); background: rgba(0, 0, 0, 0.1); font-size: 0.75rem; color: var(--text-muted); text-align: center; font-weight: 500;">
            Keyboard: Ctrl+Enter to send
        </div>
    </aside>

    <!-- Main Workspace -->
    <main style="flex: 1; display: flex; flex-direction: column; overflow: hidden; position: relative;">
        <!-- Top bar controls -->
        <header style="height: 60px; border-bottom: 1px solid var(--border-color); padding: 0 1.5rem; display: flex; align-items: center; justify-content: space-between; background: var(--bg-secondary);">
            <div style="display: flex; align-items: center; gap: 1rem;">
                <span style="font-weight: 700; font-size: 0.95rem;">💬 AI Chat Studio</span>
                <select id="chat-model-select" style="background: var(--bg-primary); border: 1px solid var(--border-color); color: var(--text-primary); padding: 0.35rem 0.75rem; border-radius: 6px; font-size: 0.8rem; outline: none; cursor: pointer; font-family: inherit; font-weight: 600;">
                    <option value="google/gemini-2.0-flash">Google Gemini 2.0 Flash</option>
                    <option value="openai/gpt-4o-mini">OpenAI GPT-4o Mini</option>
                    <option value="anthropic/claude-3-haiku">Anthropic Claude 3 Haiku</option>
                    <option value="deepseek/deepseek-chat">DeepSeek Coder V2</option>
                    <option value="openrouter/auto">OpenRouter Auto</option>
                </select>
            </div>
            
            <button class="btn btn-outline btn-small" id="btn-chat-settings-toggle">⚙️ Parameters</button>
        </header>

        <!-- Message logs container -->
        <div id="chat-messages-container" style="flex: 1; overflow-y: auto; padding: 2rem 3rem; display: flex; flex-direction: column; gap: 1.5rem; scroll-behavior: smooth;">
            <div id="chat-welcome-pane" style="margin: auto; max-width: 500px; text-align: center; display: flex; flex-direction: column; gap: 1rem; color: var(--text-secondary);">
                <div style="font-size: 3rem; line-height: 1;">🤖</div>
                <h2 style="font-weight:700; color:var(--text-primary); font-size: 1.5rem;">3M Studio Sandbox</h2>
                <p style="font-size:0.85rem; line-height:1.6; color: var(--text-muted);">Ask coding questions, design WebGL meshes, debug shaders, or translate documents. All requests are securely proxied via the Repository layers.</p>
            </div>
        </div>

        <!-- Input Box -->
        <footer style="padding: 1.5rem 3rem; background: var(--bg-secondary); border-top: 1px solid var(--border-color); display: flex; flex-direction: column; gap: 0.75rem;">
            <!-- Upload attachment preview box -->
            <div id="chat-image-preview-box" style="display: none; align-items: center; gap: 0.5rem; padding: 0.25rem 0.5rem; background: var(--bg-primary); border: 1px solid var(--border-color); border-radius: 6px; width: fit-content; text-align: left;">
                <img id="chat-image-preview-img" src="" style="height: 40px; border-radius: 4px; object-fit: cover;">
                <span id="chat-image-preview-name" style="font-size: 0.75rem; color: var(--text-muted); max-width: 150px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">image.png</span>
                <button id="btn-chat-image-remove" style="background: none; border: none; color: var(--color-error); cursor: pointer; font-size: 1.25rem; line-height: 1; padding: 0 0.25rem;">&times;</button>
            </div>

            <div style="display: flex; gap: 0.75rem; align-items: flex-end; background: var(--bg-primary); border: 1px solid var(--border-color); border-radius: 12px; padding: 0.5rem 0.75rem; box-shadow: var(--shadow-sm);">
                <button id="btn-chat-attach" style="background: none; border: none; color: var(--text-muted); cursor: pointer; padding: 0.5rem; font-size: 1.25rem; line-height: 1;">📎</button>
                <input type="file" id="chat-file-input" style="display:none;" accept="image/*">
                <textarea id="chat-prompt-textarea" rows="1" placeholder="Type prompt here... (Ctrl+Enter to send)" style="flex: 1; background: none; border: none; color: var(--text-primary); font-size: 0.9rem; outline: none; padding: 0.5rem 0; resize: none; max-height: 200px; font-family: inherit; line-height: 1.5;"></textarea>
                <button id="btn-chat-send" class="btn btn-primary" style="padding: 0.4rem 1rem; border-radius: 8px; font-size: 0.85rem;" disabled>Send</button>
            </div>
            
            <div style="display: flex; justify-content: space-between; font-size: 0.7rem; color: var(--text-muted); padding: 0 0.5rem; font-weight: 500;">
                <span>Length: <span id="chat-char-count">0</span> characters</span>
            </div>
        </footer>
    </main>

    <!-- Right Parameters Sidebar drawer -->
    <aside id="chat-settings-sidebar" style="width: 280px; border-left: 1px solid var(--border-color); background: var(--bg-secondary); padding: 1.5rem; display: none; flex-direction: column; gap: 1.5rem; flex-shrink: 0; text-align: left; box-sizing: border-box;">
        <h3 style="font-size: 1rem; font-weight: 700; border-bottom: 1px solid var(--border-color); padding-bottom: 0.5rem; margin-bottom: 0.5rem;">Parameters</h3>
        
        <div class="form-group">
            <label class="form-label" for="param-temperature">Temperature</label>
            <input type="range" id="param-temperature" min="0" max="2" step="0.1" value="0.7" style="width:100%;">
            <div style="display:flex; justify-content:space-between; font-size:0.75rem; color:var(--text-muted);">
                <span>Precise</span>
                <span id="val-temperature">0.7</span>
                <span>Creative</span>
            </div>
        </div>

        <div class="form-group">
            <label class="form-label" for="param-max-tokens">Max Tokens</label>
            <input type="number" id="param-max-tokens" class="form-control" value="2048" min="1" max="8192">
        </div>
    </aside>
</div>

<!-- Load client page controller script -->
<script src="/assets/js/ai/chat.js"></script>
