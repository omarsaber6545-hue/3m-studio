<div class="container" style="padding: 3rem 1.5rem; display: flex; flex-direction: column; gap: 2rem; text-align: left; box-sizing: border-box;">
    <!-- Welcome row -->
    <header style="display: flex; justify-content: space-between; align-items: flex-end; border-bottom: 1px solid var(--border-color); padding-bottom: 1.5rem;">
        <div>
            <span style="font-size: 0.75rem; font-weight: 700; color: var(--color-accent, #8b5cf6); text-transform: uppercase; letter-spacing: 0.05em; display: block; margin-bottom: 0.5rem;">Workspace Overview</span>
            <h1 style="font-size: 2.25rem; font-weight: 800; margin: 0;">Welcome back, <%= typeof user !== 'undefined' && user ? user.displayName || user.username : 'Creator' %> 👋</h1>
        </div>
        <div style="font-size: 0.85rem; color: var(--text-muted); font-weight: 500;">
            Plan: <span style="color: var(--color-accent, #8b5cf6); font-weight: 700; text-transform: uppercase;"><%= typeof user !== 'undefined' && user && user.profile ? 'Pro Tier' : 'Free Tier' %></span>
        </div>
    </header>

    <!-- Metrics Cards Grid -->
    <section class="grid grid-3">
        <div class="glass-card" style="display: flex; flex-direction: column; gap: 0.5rem;">
            <span style="font-size: 0.7rem; font-weight: 700; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.05em;">Tokens Remaining</span>
            <div style="font-size: 2rem; font-weight: 800; color: var(--text-primary);">48,250 <span style="font-size: 0.9rem; color: var(--text-muted); font-weight: 500;">/ 50k</span></div>
            <div style="width: 100%; height: 6px; background: rgba(255,255,255,0.06); border-radius: 99px; overflow: hidden; margin-top: 0.5rem;">
                <div style="width: 96%; height: 100%; background: var(--color-accent, #8b5cf6); border-radius: 99px;"></div>
            </div>
        </div>
        
        <div class="glass-card" style="display: flex; flex-direction: column; gap: 0.5rem;">
            <span style="font-size: 0.7rem; font-weight: 700; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.05em;">Generations Count</span>
            <div style="font-size: 2rem; font-weight: 800; color: var(--text-primary);">124 <span style="font-size: 0.9rem; color: var(--text-muted); font-weight: 500;">requests</span></div>
            <span style="font-size: 0.75rem; color: var(--color-accent, #8b5cf6); font-weight: 600;">+12% vs last week</span>
        </div>

        <div class="glass-card" style="display: flex; flex-direction: column; gap: 0.5rem;">
            <span style="font-size: 0.7rem; font-weight: 700; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.05em;">Storage Capacity</span>
            <div style="font-size: 2rem; font-weight: 800; color: var(--text-primary);">12.5 MB <span style="font-size: 0.9rem; color: var(--text-muted); font-weight: 500;">/ 2 GB</span></div>
            <div style="width: 100%; height: 6px; background: rgba(255,255,255,0.06); border-radius: 99px; overflow: hidden; margin-top: 0.5rem;">
                <div style="width: 1%; height: 100%; background: #10b981; border-radius: 99px;"></div>
            </div>
        </div>
    </section>

    <!-- Main Workspace columns -->
    <div style="display: grid; grid-template-columns: 2fr 1.2fr; gap: 2rem; width: 100%;">
        <!-- Left Pane: Pinned AI Tools -->
        <div style="display: flex; flex-direction: column; gap: 1rem;">
            <h2 style="font-size: 1.25rem; font-weight: 700; margin-bottom: 0.5rem;">📌 Pinned AI Workspaces</h2>
            <div class="grid grid-2">
                <a href="/pages/ai/chat" class="glass-card" style="text-decoration: none; color: var(--text-primary); transition: transform 0.2s;">
                    <span style="font-size: 1.75rem;">💬</span>
                    <h3 style="font-size: 1rem; margin: 0.75rem 0 0.25rem;">Chat Space</h3>
                    <p style="font-size: 0.75rem; color: var(--text-muted); line-height: 1.5; margin: 0;">Multi-model conversation logs sandbox.</p>
                </a>
                
                <a href="/pages/ai/image-generator" class="glass-card" style="text-decoration: none; color: var(--text-primary); transition: transform 0.2s;">
                    <span style="font-size: 1.75rem;">🎨</span>
                    <h3 style="font-size: 1rem; margin: 0.75rem 0 0.25rem;">Image Generator</h3>
                    <p style="font-size: 0.75rem; color: var(--text-muted); line-height: 1.5; margin: 0;">High fidelity text-to-graphics synthesis.</p>
                </a>
                
                <a href="/pages/ai/code-generator" class="glass-card" style="text-decoration: none; color: var(--text-primary); transition: transform 0.2s;">
                    <span style="font-size: 1.75rem;">💻</span>
                    <h3 style="font-size: 1rem; margin: 0.75rem 0 0.25rem;">Code Generator</h3>
                    <p style="font-size: 0.75rem; color: var(--text-muted); line-height: 1.5; margin: 0;">Compile and test WebGL or mesh scripts.</p>
                </a>

                <a href="/pages/ai/pdf-chat" class="glass-card" style="text-decoration: none; color: var(--text-primary); transition: transform 0.2s;">
                    <span style="font-size: 1.75rem;">📄</span>
                    <h3 style="font-size: 1rem; margin: 0.75rem 0 0.25rem;">Chat with PDF</h3>
                    <p style="font-size: 0.75rem; color: var(--text-muted); line-height: 1.5; margin: 0;">Query statistics from uploaded docs.</p>
                </a>
            </div>
        </div>

        <!-- Right Pane: Recent Activity Audit Logs -->
        <div style="display: flex; flex-direction: column; gap: 1rem; text-align: left;">
            <h2 style="font-size: 1.25rem; font-weight: 700; margin-bottom: 0.5rem;">🕒 Recent Activity</h2>
            <div class="glass-card" style="display: flex; flex-direction: column; gap: 1.25rem; padding: 1.5rem;">
                <div style="display: flex; gap: 0.75rem; align-items: flex-start;">
                    <span style="font-size: 1.25rem;">👤</span>
                    <div>
                        <div style="font-size: 0.8rem; font-weight: 600; color: var(--text-primary);">Account Login</div>
                        <div style="font-size: 0.75rem; color: var(--text-muted);">Session token signed and verified</div>
                        <span style="font-size: 0.65rem; color: var(--text-muted);">Just now</span>
                    </div>
                </div>
                
                <div style="display: flex; gap: 0.75rem; align-items: flex-start;">
                    <span style="font-size: 1.25rem;">🔑</span>
                    <div>
                        <div style="font-size: 0.8rem; font-weight: 600; color: var(--text-primary);">API Key Connected</div>
                        <div style="font-size: 0.75rem; color: var(--text-muted);">Custom Google Gemini key configured</div>
                        <span style="font-size: 0.65rem; color: var(--text-muted);">2 hours ago</span>
                    </div>
                </div>
                
                <div style="display: flex; gap: 0.75rem; align-items: flex-start;">
                    <span style="font-size: 1.25rem;">💬</span>
                    <div>
                        <div style="font-size: 0.8rem; font-weight: 600; color: var(--text-primary);">Synthesized Text</div>
                        <div style="font-size: 0.75rem; color: var(--text-muted);">Prompt: "Write a WebGL canvas loader"</div>
                        <span style="font-size: 0.65rem; color: var(--text-muted);">1 day ago</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
