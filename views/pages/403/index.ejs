            color: #9ca3af;
            margin: 10px 0 30px;
            max-width: 450px;
            line-height: 1.6;
        }
        a {
            color: #ffffff;
            text-decoration: none;
            border: 1px solid #ef4444;
            background: #ef4444;
            padding: 12px 28px;
            border-radius: 8px;
            font-weight: 600;
            transition: all 0.2s ease;
        }
        a:hover {
            background: transparent;
            color: #ef4444;
        }
