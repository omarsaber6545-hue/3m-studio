<div class="container" style="padding: 3rem 1.5rem; display: flex; flex-direction: column; gap: 2rem; text-align: left; box-sizing: border-box;">
    <!-- Welcome row -->
    <header style="border-bottom: 1px solid var(--border-color); padding-bottom: 1.5rem;">
        <span style="font-size: 0.75rem; font-weight: 700; color: var(--color-accent, #8b5cf6); text-transform: uppercase; letter-spacing: 0.05em; display: block; margin-bottom: 0.5rem;">User Account Settings</span>
        <h1 style="font-size: 2.25rem; font-weight: 800; margin: 0;">Profile Space</h1>
    </header>

    <!-- Profile setup panel -->
    <div style="display: grid; grid-template-columns: 1fr 2fr; gap: 2rem; width: 100%;">
        <!-- Avatar card -->
        <div class="glass-card" style="display: flex; flex-direction: column; align-items: center; text-align: center; gap: 1rem;">
            <img src="<%= typeof user !== 'undefined' && user && user.profile && user.profile.avatar ? user.profile.avatar : 'https://cdn.pixabay.com/photo/2015/10/05/22/37/blank-profile-picture-973460_1280.png' %>" style="width: 120px; height: 120px; border-radius: 50%; object-fit: cover; border: 4px solid var(--border-color); background: var(--bg-primary);">
            <div>
                <h3 style="font-size: 1.15rem; font-weight: 700; margin: 0;"><%= typeof user !== 'undefined' && user ? user.displayName || user.username : 'Creator' %></h3>
                <span style="font-size: 0.8rem; color: var(--text-muted);"><%= typeof user !== 'undefined' && user ? user.email : '' %></span>
            </div>
            <button class="btn btn-outline btn-small w-full">Upload New Avatar</button>
        </div>

        <!-- Form fields -->
        <div class="glass-card" style="display: flex; flex-direction: column; gap: 1.25rem;">
            <div style="font-weight: 700; font-size: 1.1rem; border-bottom: 1px solid var(--border-color); padding-bottom: 0.5rem; margin-bottom: 0.5rem;">Account Details</div>
            
            <div class="form-group">
                <label class="form-label" for="profile-display-name">Display Name</label>
                <input type="text" id="profile-display-name" class="form-control" value="<%= typeof user !== 'undefined' && user ? user.displayName || user.username : '' %>">
            </div>

            <div class="form-group">
                <label class="form-label" for="profile-bio">Bio</label>
                <textarea id="profile-bio" class="form-control" rows="3" style="resize:none;"><%= typeof user !== 'undefined' && user && user.profile ? user.profile.bio : '' %></textarea>
            </div>

            <!-- Connected Accounts -->
            <div style="font-weight: 700; font-size: 1rem; border-bottom: 1px solid var(--border-color); padding-bottom: 0.5rem; margin-top: 1rem; margin-bottom: 0.5rem;">Connected Integrations</div>
            <div style="display: flex; align-items: center; justify-content: space-between; padding: 0.75rem 1rem; background: rgba(255,255,255,0.02); border: 1px solid var(--border-color); border-radius: 8px;">
                <div style="display:flex; align-items:center; gap:0.5rem; font-size: 0.85rem;">
                    <span style="font-size: 1.25rem;">🎮</span>
                    <div>
                        <div style="font-weight: 600;">Discord Connection</div>
                        <div style="font-size: 0.75rem; color: var(--text-muted);"><%= typeof user !== 'undefined' && user && user.profile && user.profile.bio && user.profile.bio.includes('discord_id:') ? 'Linked successfully' : 'Not connected' %></div>
                    </div>
                </div>
                <% if (typeof user !== 'undefined' && user && user.profile && user.profile.bio && user.profile.bio.includes('discord_id:')) { %>
                    <span style="font-size: 0.75rem; color: #10b981; font-weight: 700;">CONNECTED</span>
                <% } else { %>
                    <a href="/api/v1/auth/discord" class="btn btn-outline btn-small" style="font-size:0.75rem;">Link Account</a>
                <% } %>
            </div>

            <button class="btn btn-primary" style="align-self: flex-start; margin-top: 1rem;">Save Settings</button>
        </div>
    </div>
</div>
