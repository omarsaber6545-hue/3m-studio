<!DOCTYPE html>
<html lang="en" dir="ltr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= typeof title !== 'undefined' ? title : 'Administration | 3M Studio' %></title>
    
    <!-- Core Style Tokens -->
    <link rel="stylesheet" href="/assets/css/variables.css">
    <link rel="stylesheet" href="/assets/css/base.css">
    <link rel="stylesheet" href="/assets/css/layout.css">
    <link rel="stylesheet" href="/assets/css/components.css">
    <link rel="stylesheet" href="/assets/css/animations.css">
    
    <link rel="stylesheet" id="theme-style" href="/assets/css/themes/dark.css">
    <link rel="stylesheet" id="rtl-style" href="/assets/css/themes/rtl.css" disabled>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&family=Cairo:wght@300;400;600;700;800&display=swap" rel="stylesheet">
    
    <style>
        .admin-layout-container {
            display: flex;
            min-height: 100vh;
            background: var(--bg-primary);
        }
        .admin-main-viewport {
            flex: 1;
            display: flex;
            flex-direction: column;
            overflow-x: hidden;
        }
        .admin-topbar {
            height: 64px;
            border-bottom: 1px solid var(--border-color);
            background: var(--bg-secondary);
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0 1.5rem;
        }
        .admin-content-pane {
            flex: 1;
            padding: 2rem;
            overflow-y: auto;
        }
    </style>
</head>
<body>
    <!-- Screen Loader -->
    <%- include('../partials/loader') %>
    
    <!-- Global Toasts -->
    <%- include('../partials/toast') %>

    <div class="admin-layout-container">
        <!-- Admin Navigation Sidebar Drawer -->
        <%- include('../partials/sidebar') %>

        <div class="admin-main-viewport">
            <!-- Top Controls bar -->
            <header class="admin-topbar">
                <div style="font-weight: 700; font-size: 1.1rem; color: var(--text-primary);">
                    🛡️ Admin Console
                </div>
                <div style="display: flex; align-items: center; gap: 1rem;">
                    <%- include('../partials/theme-switcher') %>
                    <%- include('../partials/language-switcher') %>
                    <%- include('../partials/profile-menu') %>
                </div>
            </header>

            <!-- Main Render Area -->
            <main class="admin-content-pane">
                <%- body %>
            </main>
        </div>
    </div>

    <!-- Core preferences scripts -->
    <script src="/assets/js/core/storage.js"></script>
    <script src="/assets/js/core/theme.js"></script>
    <script src="/assets/js/core/language.js"></script>
    <script src="/assets/js/ui/toast.js"></script>
</body>
</html>
