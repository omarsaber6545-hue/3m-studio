<div id="global-loader" style="position: fixed; inset: 0; background: #0b0f19; display: flex; align-items: center; justify-content: center; z-index: 9999; transition: opacity 0.4s ease, visibility 0.4s;">
    <div style="display: flex; flex-direction: column; align-items: center; gap: 1.25rem;">
        <!-- Circular spinner -->
        <div style="width: 48px; height: 48px; border: 3px solid rgba(139, 92, 246, 0.15); border-top-color: var(--color-accent, #8b5cf6); border-radius: 50%; animation: loader-spin 0.8s linear infinite;"></div>
        <div style="font-weight: 600; font-size: 0.8rem; color: var(--color-accent, #8b5cf6); letter-spacing: 0.1em; text-transform: uppercase;">
            Loading 3M Studio
        </div>
    </div>
</div>

<style>
    @keyframes loader-spin {
        to { transform: rotate(360deg); }
    }
</style>

<script>
    window.addEventListener('DOMContentLoaded', () => {
        const loader = document.getElementById('global-loader');
        if (loader) {
            setTimeout(() => {
                loader.style.opacity = '0';
                loader.style.visibility = 'hidden';
            }, 250);
        }
    });
</script>
