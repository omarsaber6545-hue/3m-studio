<button id="btn-theme-toggle" class="btn-theme-toggle" aria-label="Toggle Color Theme" style="background: none; border: none; color: var(--text-primary); cursor: pointer; padding: 0.5rem; font-size: 1.2rem; display: flex; align-items: center; justify-content: center; border-radius: 8px; transition: background 0.2s; width: 36px; height: 36px;">
    <span class="theme-icon-dark" style="line-height: 1;">🌙</span>
    <span class="theme-icon-light" style="display: none; line-height: 1;">☀️</span>
</button>
