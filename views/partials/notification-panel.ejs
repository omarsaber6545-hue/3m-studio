<div id="notification-panel" style="display: none; position: absolute; right: 0; top: 120%; width: 320px; background: var(--bg-secondary); border: 1px solid var(--border-color); border-radius: 8px; box-shadow: 0 10px 25px -5px rgba(0,0,0,0.4); z-index: 1000; text-align: left; overflow: hidden; font-family: inherit;">
    <div style="padding: 1rem; border-bottom: 1px solid var(--border-color); display: flex; justify-content: space-between; align-items: center; background: rgba(0,0,0,0.15);">
        <span style="font-weight: 700; font-size: 0.85rem; color: var(--text-primary);">Notifications</span>
        <button id="btn-notifications-clear" style="background: none; border: none; color: var(--color-accent, #8b5cf6); font-size: 0.75rem; cursor: pointer; font-weight: 600; font-family: inherit; padding: 0.25rem;">Mark read</button>
    </div>
    
    <div id="notifications-list" style="max-height: 280px; overflow-y: auto; padding: 0.5rem; display: flex; flex-direction: column; gap: 0.5rem;">
        <div style="padding: 0.75rem; border-radius: 6px; background: rgba(255,255,255,0.02); font-size: 0.8rem; border-left: 3px solid var(--color-accent, #8b5cf6); text-align: left;">
            <div style="font-weight: 600; color: var(--text-primary); margin-bottom: 0.15rem;">Welcome to 3M Studio!</div>
            <div style="color: var(--text-secondary); font-size: 0.75rem; line-height: 1.4;">Explore our 17 standalone AI generators via the Navbar Mega Menu.</div>
            <div style="font-size: 0.65rem; color: var(--text-muted); margin-top: 0.5rem;">Just now</div>
        </div>
    </div>
</div>
