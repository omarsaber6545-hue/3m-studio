# Server Configuration
PORT=5000
NODE_ENV=development

# Database Connection (PostgreSQL preferred)
DATABASE_URL="postgresql://username:password@localhost:5432/three_m_studio_db?schema=public"

# Authentication Secrets
JWT_SECRET="super_secret_jwt_access_signing_key_change_in_production"
JWT_REFRESH_SECRET="super_secret_jwt_refresh_signing_key_change_in_production"
JWT_ACCESS_EXPIRATION="15m"
JWT_REFRESH_EXPIRATION="7d"

# Storage Settings
UPLOAD_DIR="./uploads"
MAX_FILE_SIZE_MB=50

# AI API Providers Keys
OPENAI_API_KEY=""
GEMINI_API_KEY=""
CLAUDE_API_KEY=""
OPENROUTER_API_KEY=""
DEEPSEEK_API_KEY=""

# Payments & Billing (Stripe Simulation ready)
STRIPE_API_KEY=""
STRIPE_WEBHOOK_SECRET=""

# Email System (SMTP/Mailgun ready)
SMTP_HOST="smtp.mailtrap.io"
SMTP_PORT=2525
SMTP_USER=""
SMTP_PASS=""
EMAIL_FROM="no-reply@3mstudio.design"
